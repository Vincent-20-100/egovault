# ============================================================
# INSTALL CONFIGURATION — gitignored, never commit this file
# Machine-specific paths and secrets
# Copy this file to install.yaml and fill in your values
# ============================================================

paths:
  user_dir: "../egovault-user"    # root for data/ and vault/
  # optional overrides (default: user_dir/data and user_dir/vault)
  data_dir: null
  vault_dir: null
  media_dir: null
  db_file: null

providers:
  ollama_base_url: "http://localhost:11434"
  # API keys for external providers — NEVER commit real keys.
  # If set, your data (note text, queries) will be sent to the provider's API.
  openai_api_key: null
  anthropic_api_key: null
